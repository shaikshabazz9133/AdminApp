{
  "expo": {
    "name": "MNC Admin",
    "slug": "mnc-admin-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mnc.adminapp"
    },
    "android": {
      "package": "com.mnc.adminapp"
    },
    "web": {
      "bundler": "metro",
      "output": "spa"
    },
    "plugins": ["expo-font"]
  }
}
